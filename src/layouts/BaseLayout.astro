---
import "katex/dist/katex.min.css";

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "公开整理的学习笔记与研究笔记。"
} = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <style>
      :root {
        color-scheme: light;
        --bg: #f4efe8;
        --panel: rgba(255, 250, 244, 0.9);
        --panel-strong: #fffdf9;
        --text: #1f1a17;
        --muted: #72655b;
        --accent: #0f766e;
        --accent-soft: rgba(15, 118, 110, 0.12);
        --border: rgba(31, 26, 23, 0.1);
        --shadow: 0 18px 40px rgba(55, 38, 22, 0.08);
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        font-family: "Segoe UI", "PingFang SC", "Hiragino Sans GB", sans-serif;
        color: var(--text);
        background:
          radial-gradient(circle at top left, rgba(15, 118, 110, 0.1), transparent 28%),
          radial-gradient(circle at top right, rgba(180, 83, 9, 0.1), transparent 26%),
          var(--bg);
        min-height: 100vh;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      .page :global(.katex-display) {
        overflow-x: auto;
        overflow-y: hidden;
        padding: 0.6rem 0;
      }

      .page :global(.katex) {
        font-size: 1.05em;
      }

      .shell {
        width: min(1160px, calc(100vw - 32px));
        margin: 0 auto;
        padding: 24px 0 48px;
      }

      .topbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 16px;
        margin-bottom: 32px;
        padding: 16px 20px;
        background: var(--panel);
        border: 1px solid var(--border);
        border-radius: 16px;
        box-shadow: var(--shadow);
        backdrop-filter: blur(18px);
      }

      .brand {
        display: grid;
        gap: 4px;
      }

      .brand strong {
        font-size: 1rem;
      }

      .brand span {
        font-size: 0.9rem;
        color: var(--muted);
      }

      nav {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
      }

      nav a {
        padding: 8px 12px;
        border-radius: 999px;
        color: var(--muted);
      }

      nav a:hover {
        background: var(--accent-soft);
        color: var(--accent);
      }

      .page {
        display: grid;
        gap: 24px;
      }

      .panel {
        background: var(--panel-strong);
        border: 1px solid var(--border);
        border-radius: 20px;
        box-shadow: var(--shadow);
      }

      .section {
        padding: 24px;
      }

      .eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 6px 10px;
        border-radius: 999px;
        background: var(--accent-soft);
        color: var(--accent);
        font-size: 0.84rem;
      }

      .hero-title {
        margin: 16px 0 10px;
        font-size: clamp(2rem, 5vw, 3.8rem);
        line-height: 1.02;
      }

      .hero-copy {
        margin: 0;
        max-width: 720px;
        color: var(--muted);
        font-size: 1rem;
        line-height: 1.7;
      }

      .footer {
        margin-top: 32px;
        color: var(--muted);
        font-size: 0.92rem;
        text-align: center;
      }

      @media (max-width: 720px) {
        .shell {
          width: min(100vw - 20px, 1160px);
          padding-top: 16px;
        }

        .topbar {
          align-items: flex-start;
          flex-direction: column;
        }

        .section {
          padding: 18px;
        }
      }
    </style>
  </head>
  <body>
    <div class="shell">
      <header class="topbar">
        <a class="brand" href="/">
          <strong>Knowledge Notes</strong>
          <span>从 Obsidian 整理出来的公开学习笔记</span>
        </a>
        <nav aria-label="Site">
          <a href="/">首页</a>
          <a href="/notes/">全部笔记</a>
          <a href="/categories/">分类</a>
          <a href="/tags/">标签</a>
        </nav>
      </header>
      <main class="page">
        <slot />
      </main>
      <footer class="footer">
        Built from a private notes vault with a publish layer and Astro.
      </footer>
    </div>
  </body>
</html>
