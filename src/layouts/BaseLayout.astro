---
import "katex/dist/katex.min.css";
import { getCollection } from "astro:content";
import SidebarNav from "../components/SidebarNav.astro";
import { sortNotes, groupNotesByCategory } from "../lib/notes";
import { SITE_BASE, sitePath } from "../lib/site-paths";
import "../styles/tokens.css";
import "../styles/base.css";
import "../styles/prose.css";

interface Props {
  title: string;
  description?: string;
  layout?: "default" | "reading";
}

const {
  title,
  description = "学习记录与笔记随想",
  layout = "default"
} = Astro.props;
const pageTitle = title === "Knowledge Notes" ? title : `${title} | Knowledge Notes`;
const isReadingLayout = layout === "reading";

const notes = sortNotes((await getCollection("notes")).filter((entry) => !entry.data.draft));
const categories = groupNotesByCategory(notes);
const recentNotes = notes.slice(0, 5);
const currentPath = Astro.url.pathname;
const isCurrent = (href: string) =>
  href === SITE_BASE ? currentPath === SITE_BASE || currentPath === SITE_BASE.slice(0, -1) : currentPath.startsWith(href);
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={sitePath("favicon.svg")} />
  </head>
  <body>
    <div class={isReadingLayout ? "shell shell-reading" : "shell"}>
      <header class="site-topbar">
        <a class="site-brand" href={SITE_BASE}>
          <strong>Knowledge Notes</strong>
          <span>学习记录与笔记随想</span>
        </a>
        <nav class="site-nav" aria-label="Site">
          <a href={SITE_BASE} aria-current={isCurrent(SITE_BASE) ? "page" : undefined}>首页</a>
          <a href={sitePath("notes/")} aria-current={isCurrent(sitePath("notes/")) ? "page" : undefined}>
            笔记
          </a>
          <a
            href={sitePath("categories/")}
            aria-current={isCurrent(sitePath("categories/")) ? "page" : undefined}
          >
            分类
          </a>
          <a href={sitePath("tags/")} aria-current={isCurrent(sitePath("tags/")) ? "page" : undefined}>
            标签
          </a>
        </nav>
      </header>

      <div class={isReadingLayout ? "page-grid page-grid-reading" : "page-grid"}>
        {!isReadingLayout && <SidebarNav currentPath={currentPath} categories={categories} recentNotes={recentNotes} />}
        <main class={isReadingLayout ? "page-main page-main-reading" : "page-main"}>
          <slot />
        </main>
      </div>

      <footer class="site-footer">Knowledge compiles into wisdom</footer>
    </div>
  </body>
</html>
