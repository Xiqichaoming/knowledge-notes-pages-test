---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import NoteCard from "../components/NoteCard.astro";
import NoteListItem from "../components/NoteListItem.astro";
import SectionIntro from "../components/SectionIntro.astro";
import { groupNotesByCategory, sortNotes } from "../lib/notes";
import { sitePath } from "../lib/site-paths";

const notes = sortNotes((await getCollection("notes")).filter((entry) => !entry.data.draft));
const featured = notes[0];
const recentNotes = notes.slice(1, 4);
const categories = groupNotesByCategory(notes);
---

<BaseLayout title="Knowledge Notes" description="公开整理的学习笔记与研究笔记。">
  <SectionIntro
    eyebrow="公开站"
    title="研究笔记应该像一个可浏览的知识库，而不是散乱的文件夹。"
    copy="这里发布的是从私有 Obsidian 知识库中筛选和整理出来的公开内容。每篇笔记都保留专题上下文，便于持续扩展和回看。"
  />

  <section class="hero-grid">
    <article class="surface section feature-card">
      <div class="section-head">
        <h2>精选笔记</h2>
        <a href={sitePath(`notes/${featured.slug}/`)}>阅读全文</a>
      </div>
      <span class="eyebrow">{featured.data.categoryLabel}</span>
      <h3>
        <a href={sitePath(`notes/${featured.slug}/`)}>{featured.data.title}</a>
      </h3>
      <p>{featured.data.summary}</p>
      <div class="meta-line">
        <span>{featured.data.updated}</span>
        <span>{featured.data.tags.length} 个标签</span>
      </div>
      <div class="chip-row">
        {featured.data.tags.map((tag) => (
          <a class="chip" href={sitePath(`tags/${tag}/`)}>
            #{tag}
          </a>
        ))}
      </div>
    </article>

    <section class="surface section">
      <div class="section-head">
        <h2>最近更新</h2>
        <a href={sitePath("notes/")}>查看全部</a>
      </div>
      <div class="recent-stack">
        {recentNotes.map((note) => (
          <NoteListItem
            slug={note.slug}
            title={note.data.title}
            summary={note.data.summary}
            categoryLabel={note.data.categoryLabel}
            updated={note.data.updated}
            tags={note.data.tags}
          />
        ))}
      </div>
    </section>
  </section>

  <section class="surface section">
    <div class="section-head">
      <h2>专题入口</h2>
      <a href={sitePath("categories/")}>完整分类</a>
    </div>
    <div class="topic-grid">
      {categories.map((category) => (
        <a class="topic-card" href={sitePath(`categories/${category.slug}/`)}>
          <span>{category.label}</span>
          <strong>{category.count} 篇笔记</strong>
          <p>{category.notes[0]?.data.summary ?? ""}</p>
        </a>
      ))}
    </div>
  </section>

  <section class="surface section">
    <div class="section-head">
      <h2>归档速览</h2>
      <a href={sitePath("notes/")}>进入归档</a>
    </div>
    <div class="archive-grid">
      {notes.map((note) => (
        <NoteCard
          href={sitePath(`notes/${note.slug}/`)}
          title={note.data.title}
          summary={note.data.summary}
          categoryLabel={note.data.categoryLabel}
          updated={note.data.updated}
          tags={note.data.tags}
        />
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(0, 0.9fr);
    gap: 24px;
    align-items: start;
  }

  .feature-card {
    display: grid;
    justify-items: start;
    gap: 16px;
    align-content: start;
  }

  .feature-card h3 {
    margin: 0;
    font-family: var(--font-serif);
    font-size: 2rem;
    font-weight: 600;
    line-height: 1.08;
  }

  .feature-card h3 a:hover {
    color: var(--accent);
  }

  .feature-card p {
    margin: 0;
    color: var(--text-soft);
    line-height: 1.75;
  }

  .recent-stack {
    display: grid;
  }

  .topic-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 18px;
  }

  .topic-card {
    display: grid;
    gap: 10px;
    padding: 20px;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: rgba(255, 249, 242, 0.72);
  }

  .topic-card:hover {
    border-color: var(--accent-line);
    box-shadow: var(--shadow-soft);
  }

  .topic-card span {
    color: var(--text-muted);
    font-size: 0.88rem;
  }

  .topic-card strong {
    font-family: var(--font-serif);
    font-size: 1.2rem;
    font-weight: 600;
  }

  .topic-card p {
    margin: 0;
    color: var(--text-soft);
    line-height: 1.65;
  }

  .archive-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 18px;
  }

  @media (max-width: 1080px) {
    .hero-grid,
    .topic-grid,
    .archive-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
