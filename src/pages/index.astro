---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import NoteCard from "../components/NoteCard.astro";
import NoteListItem from "../components/NoteListItem.astro";
import SectionIntro from "../components/SectionIntro.astro";
import { groupNotesByCategory, sortNotes } from "../lib/notes";
import { sitePath } from "../lib/site-paths";
import { cleanDisplayText } from "../lib/display-text";

const notes = sortNotes((await getCollection("notes")).filter((entry) => !entry.data.draft));
const featuredNotes = notes.slice(0, 2);
const recentNotes = notes.slice(2, 5);
const categories = groupNotesByCategory(notes);
---

<BaseLayout title="Knowledge Notes" description="学习记录与笔记随想">
  <SectionIntro
    title="学习整理出的可以回看的知识记录"
    copy="个人的学习记录与笔记随想"
  />

  <section class="surface section topic-section">
    <div class="section-head">
      <h2>专题入口</h2>
      <a href={sitePath("categories/")}>完整分类</a>
    </div>
    <div class="topic-grid">
      {categories.map((category) => (
        <a class="topic-card" href={sitePath(`categories/${category.slug}/`)}>
          <span>{category.label}</span>
          <strong>{category.count} 篇笔记</strong>
          <p>{cleanDisplayText(category.notes[0]?.data.summary ?? "")}</p>
        </a>
      ))}
    </div>
  </section>

  <section class="feature-update-grid">
    <section class="surface section">
      <div class="section-head">
        <h2>精选笔记</h2>
        <a href={sitePath("notes/")}>查看全部</a>
      </div>
      <div class="featured-grid">
        {featuredNotes.map((note) => (
          <NoteCard
            href={sitePath(`notes/${note.slug}/`)}
            title={note.data.title}
            summary={note.data.summary}
            categoryLabel={note.data.categoryLabel}
            updated={note.data.updated}
            tags={note.data.tags}
          />
        ))}
      </div>
    </section>

    <section class="surface section recent-panel">
      <div class="section-head">
        <h2>最近更新</h2>
        <a href={sitePath("notes/")}>进入归档</a>
      </div>
      <div class="recent-scroll">
        {recentNotes.map((note) => (
          <NoteListItem
            slug={note.slug}
            title={note.data.title}
            summary={note.data.summary}
            categoryLabel={note.data.categoryLabel}
            updated={note.data.updated}
            tags={note.data.tags}
          />
        ))}
      </div>
    </section>
  </section>

  <section class="surface section">
    <div class="section-head">
      <h2>归档速览</h2>
      <a href={sitePath("notes/")}>进入归档</a>
    </div>
    <div class="archive-grid">
      {notes.map((note) => (
        <NoteCard
          href={sitePath(`notes/${note.slug}/`)}
          title={note.data.title}
          summary={note.data.summary}
          categoryLabel={note.data.categoryLabel}
          updated={note.data.updated}
          tags={note.data.tags}
        />
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .feature-update-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(0, 0.9fr);
    gap: 24px;
    align-items: start;
  }

  .section-head {
    margin-bottom: 18px;
  }

  .featured-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 18px;
  }

  .recent-panel {
    max-height: 380px;
    overflow: hidden;
  }

  .recent-scroll {
    display: grid;
    max-height: 292px;
    overflow-y: auto;
    padding-right: 8px;
    scrollbar-gutter: stable;
  }

  .recent-scroll::-webkit-scrollbar {
    width: 8px;
  }

  .recent-scroll::-webkit-scrollbar-track {
    background: rgba(31, 26, 23, 0.05);
    border-radius: 999px;
  }

  .recent-scroll::-webkit-scrollbar-thumb {
    background: rgba(15, 118, 110, 0.22);
    border-radius: 999px;
  }

  .recent-scroll::-webkit-scrollbar-thumb:hover {
    background: rgba(15, 118, 110, 0.34);
  }

  .topic-section {
    display: grid;
  }

  .topic-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 18px;
  }

  .topic-card {
    display: grid;
    gap: 10px;
    padding: 20px;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: rgba(255, 249, 242, 0.72);
  }

  .topic-card:hover {
    border-color: var(--accent-line);
    box-shadow: var(--shadow-soft);
  }

  .topic-card span {
    color: var(--text-muted);
    font-size: 0.88rem;
  }

  .topic-card strong {
    font-family: var(--font-serif);
    font-size: 1.2rem;
    font-weight: 600;
  }

  .topic-card p {
    margin: 0;
    color: var(--text-soft);
    line-height: 1.65;
  }

  .archive-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 18px;
  }

  @media (max-width: 1080px) {
    .feature-update-grid,
    .featured-grid,
    .topic-grid,
    .archive-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
