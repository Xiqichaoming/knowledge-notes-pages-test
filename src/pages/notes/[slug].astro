---
import readingTime from "reading-time";
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import NoteMeta from "../../components/NoteMeta.astro";
import PrevNextNav from "../../components/PrevNextNav.astro";
import RelatedNotes from "../../components/RelatedNotes.astro";
import { buildPrevNext, buildRelated, sortNotes } from "../../lib/notes";
import { sitePath } from "../../lib/site-paths";
import { cleanDisplayText } from "../../lib/display-text";

export async function getStaticPaths() {
  const notes = await getCollection("notes");
  return notes
    .filter((entry) => !entry.data.draft)
    .map((entry) => ({
      params: { slug: entry.slug },
      props: { entry }
    }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);
const notes = sortNotes((await getCollection("notes")).filter((item) => !item.data.draft));
const { previous, next } = buildPrevNext(notes, entry.slug);
const relatedNotes = buildRelated(notes, entry);
const reading = readingTime(entry.body);
const displaySummary = cleanDisplayText(entry.data.summary);
---

<BaseLayout title={entry.data.title} description={displaySummary} layout="reading">
  <section class="surface section article-frame">
    <Breadcrumbs
      items={[
        { href: sitePath("categories/"), label: "分类" },
        { href: sitePath(`categories/${entry.data.category}/`), label: entry.data.categoryLabel },
        { label: entry.data.title }
      ]}
    />

    <div class="article-shell">
      <article class="article-main">
        <header class="article-header">
          <span class="eyebrow">{entry.data.categoryLabel}</span>
          <h1>{entry.data.title}</h1>
          <p class="article-summary">{displaySummary}</p>
          <NoteMeta
            updated={entry.data.updated}
            readingTime={`约 ${Math.max(1, Math.round(reading.minutes))} 分钟`}
            source={entry.data.source}
          />
          <div class="chip-row">
            {entry.data.tags.map((tag) => (
              <a class="chip" href={sitePath(`tags/${tag}/`)}>
                #{tag}
              </a>
            ))}
          </div>
        </header>

        <div class="prose">
          <Content />
        </div>
      </article>

      <aside class="article-side">
        <section class="surface-muted section-tight side-panel">
          <span class="sidebar-label">本页目录</span>
          <ul class="toc-list">
            {headings
              .filter((heading) => heading.depth <= 3)
              .map((heading) => (
                <li class={`depth-${heading.depth}`}>
                  <a href={`#${heading.slug}`}>{heading.text}</a>
                </li>
              ))}
          </ul>
        </section>

        <RelatedNotes notes={relatedNotes} />
      </aside>
    </div>
  </section>

  <PrevNextNav previous={previous} next={next} />
</BaseLayout>

<style>
  .article-frame {
    display: grid;
    gap: 24px;
  }

  .article-shell {
    display: grid;
    grid-template-columns: minmax(0, var(--reading-width)) minmax(220px, 280px);
    justify-content: center;
    gap: clamp(28px, 4vw, 56px);
    align-items: start;
  }

  .article-main {
    min-width: 0;
  }

  .article-header {
    display: grid;
    justify-items: start;
    gap: 14px;
    margin-bottom: 28px;
  }

  .article-header h1 {
    margin: 0;
    font-family: var(--font-serif);
    font-size: 3rem;
    font-weight: 600;
    line-height: 1.02;
  }

  .article-summary {
    margin: 0;
    max-width: var(--reading-width);
    color: var(--text-soft);
    font-size: 1.04rem;
    line-height: 1.75;
  }

  .article-main :global(.prose) {
    max-width: var(--reading-width);
  }

  .article-side {
    display: grid;
    align-content: start;
    gap: 18px;
    position: sticky;
    top: 20px;
    max-height: calc(100vh - 40px);
    overflow-y: auto;
    padding-right: 2px;
    scrollbar-gutter: stable;
  }

  .article-side::-webkit-scrollbar {
    width: 8px;
  }

  .article-side::-webkit-scrollbar-track {
    background: rgba(31, 26, 23, 0.05);
    border-radius: 999px;
  }

  .article-side::-webkit-scrollbar-thumb {
    background: rgba(15, 118, 110, 0.22);
    border-radius: 999px;
  }

  .article-side::-webkit-scrollbar-thumb:hover {
    background: rgba(15, 118, 110, 0.34);
  }

  .toc-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 10px;
  }

  .toc-list li {
    color: var(--text-soft);
    font-size: 0.92rem;
    line-height: 1.45;
  }

  .toc-list li.depth-3 {
    padding-left: 12px;
  }

  .toc-list a:hover {
    color: var(--accent);
  }

  @media (max-width: 1120px) {
    .article-shell {
      grid-template-columns: 1fr;
    }

    .article-side {
      position: static;
      max-height: none;
      overflow: visible;
      padding-right: 0;
    }
  }

  @media (max-width: 720px) {
    .article-header h1 {
      font-size: 2.25rem;
    }

    .article-frame {
      gap: 18px;
    }
  }
</style>
