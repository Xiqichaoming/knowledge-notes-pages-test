---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const notes = await getCollection("notes");
  return notes
    .filter((entry) => !entry.data.draft)
    .map((entry) => ({
      params: { slug: entry.slug },
      props: { entry }
    }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);
---

<BaseLayout title={entry.data.title} description={entry.data.summary}>
  <div class="article-shell">
    <article class="panel article">
      <header class="article-header">
        <span class="eyebrow">{entry.data.categoryLabel}</span>
        <h1>{entry.data.title}</h1>
        <p>{entry.data.summary}</p>
        <div class="meta">
          <span>更新于 {entry.data.updated}</span>
          <span>来源：{entry.data.source}</span>
        </div>
        <div class="tags">
          {entry.data.tags.map((tag) => <a href={`/tags/${tag}/`}>#{tag}</a>)}
        </div>
      </header>
      <div class="article-body">
        <Content />
      </div>
    </article>

    <aside class="panel toc">
      <div class="toc-inner">
        <strong>目录</strong>
        <ul>
          {headings
            .filter((heading) => heading.depth <= 3)
            .map((heading) => (
              <li class={`depth-${heading.depth}`}>
                <a href={`#${heading.slug}`}>{heading.text}</a>
              </li>
            ))}
        </ul>
      </div>
    </aside>
  </div>
</BaseLayout>

<style>
  .article-shell {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 280px;
    gap: 20px;
    align-items: start;
  }

  .article {
    padding: 28px;
  }

  .article-header {
    display: grid;
    gap: 14px;
    margin-bottom: 26px;
  }

  .article-header h1 {
    margin: 0;
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1.08;
  }

  .article-header p {
    margin: 0;
    color: #5f534a;
    line-height: 1.7;
  }

  .meta {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    color: #72655b;
    font-size: 0.92rem;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .tags a {
    padding: 6px 10px;
    border-radius: 999px;
    background: rgba(15, 118, 110, 0.09);
    color: #0f766e;
    font-size: 0.84rem;
  }

  .article-body {
    line-height: 1.82;
    color: #2c241f;
  }

  .article-body :global(h2),
  .article-body :global(h3) {
    margin-top: 2rem;
    line-height: 1.2;
  }

  .article-body :global(img) {
    display: block;
    max-width: 100%;
    height: auto;
    margin: 1.4rem auto;
    border-radius: 14px;
    border: 1px solid rgba(31, 26, 23, 0.1);
  }

  .article-body :global(blockquote) {
    margin: 1.4rem 0;
    padding: 14px 18px;
    border-left: 4px solid #0f766e;
    background: rgba(15, 118, 110, 0.06);
    color: #4e433b;
  }

  .article-body :global(code) {
    padding: 0.15rem 0.38rem;
    border-radius: 6px;
    background: rgba(31, 26, 23, 0.08);
    font-size: 0.95em;
  }

  .article-body :global(pre) {
    overflow: auto;
    padding: 14px;
    border-radius: 14px;
    background: #1f1d1b;
    color: #f9f3ea;
  }

  .article-body :global(pre code) {
    padding: 0;
    background: transparent;
  }

  .toc {
    position: sticky;
    top: 20px;
    padding: 20px;
  }

  .toc-inner {
    display: grid;
    gap: 14px;
  }

  .toc strong {
    font-size: 0.95rem;
  }

  .toc ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 10px;
  }

  .toc li {
    color: #5f534a;
    font-size: 0.92rem;
  }

  .toc li.depth-3 {
    padding-left: 14px;
  }

  .toc a:hover {
    color: #0f766e;
  }

  @media (max-width: 980px) {
    .article-shell {
      grid-template-columns: 1fr;
    }

    .toc {
      position: static;
    }
  }
</style>
