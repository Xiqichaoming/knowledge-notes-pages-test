---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import SectionIntro from "../../components/SectionIntro.astro";
import { groupNotesByCategory, sortNotes } from "../../lib/notes";
import { sitePath } from "../../lib/site-paths";
import { cleanDisplayText } from "../../lib/display-text";

const notes = sortNotes((await getCollection("notes")).filter((entry) => !entry.data.draft));
const groups = groupNotesByCategory(notes);
---

<BaseLayout title="分类">
  <SectionIntro
    eyebrow="分类"
    title="按专题浏览"
    copy="分类用于收住相对稳定的学习主题，方便从一个方向持续追踪相关笔记"
  />

  <section class="surface section">
    <div class="section-head">
      <h2>专题目录</h2>
      <span class="section-summary">{groups.length} 个分类</span>
    </div>

    <div class="cards">
      {groups.map((group) => (
        <a class="card" href={sitePath(`categories/${group.slug}/`)}>
          <div class="card-meta">
            <span>{group.count} 篇笔记</span>
            {group.notes[0] && <time datetime={group.notes[0].data.updated}>{group.notes[0].data.updated}</time>}
          </div>
          <strong>{group.label}</strong>
          <p>{cleanDisplayText(group.notes[0]?.data.summary ?? "这个专题会继续扩展")} </p>
          {group.notes[0] && <span class="card-latest">最近更新：{group.notes[0].data.title}</span>}
        </a>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 360px), 1fr));
    gap: 18px;
    margin-top: 18px;
  }

  .card {
    display: grid;
    gap: 12px;
    padding: 20px;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: rgba(255, 249, 242, 0.78);
  }

  .card:hover {
    border-color: var(--accent-line);
    box-shadow: var(--shadow-soft);
  }

  .card-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 8px 16px;
    color: var(--text-muted);
    font-size: 0.85rem;
  }

  .card-meta time {
    white-space: nowrap;
  }

  .card strong {
    font-family: var(--font-serif);
    font-size: 1.3rem;
    font-weight: 600;
  }

  .card p {
    margin: 0;
    color: var(--text-soft);
    line-height: 1.7;
    text-wrap: pretty;
  }

  .card-latest,
  .section-summary {
    color: var(--text-muted);
    font-size: 0.86rem;
  }

</style>
