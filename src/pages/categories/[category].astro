---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import NoteListItem from "../../components/NoteListItem.astro";
import { groupNotesByTag, sortNotes } from "../../lib/notes";
import { sitePath } from "../../lib/site-paths";

export async function getStaticPaths() {
  const notes = (await getCollection("notes")).filter((entry) => !entry.data.draft);
  const categories = [...new Set(notes.map((entry) => entry.data.category))];
  return categories.map((category) => ({ params: { category } }));
}

const { category = "" } = Astro.params;
const notes = sortNotes(
  (await getCollection("notes")).filter((entry) => !entry.data.draft && entry.data.category === category)
);
const label = notes[0]?.data.categoryLabel ?? category;
const latestUpdated = notes[0]?.data.updated ?? "暂无";
const tagGroups = [...groupNotesByTag(notes)]
  .sort((left, right) => right.count - left.count || left.label.localeCompare(right.label))
  .slice(0, 12);
---

<BaseLayout title={label}>
  <section class="surface section">
    <Breadcrumbs items={[{ href: sitePath("categories/"), label: "分类" }, { label }]} />

    <header class="page-head">
      <span class="eyebrow">分类</span>
      <h1>{label}</h1>
      <p>这个专题目前公开了 {notes.length} 篇笔记，最近一次整理时间是 {latestUpdated}。</p>
    </header>
  </section>

  <div class="detail-grid">
    <section class="surface section">
      <div class="section-head">
        <h2>分类下的笔记</h2>
        <span class="section-summary">{notes.length} 篇</span>
      </div>
      <div class="note-stack">
        {notes.map((note) => (
          <NoteListItem
            slug={note.slug}
            title={note.data.title}
            summary={note.data.summary}
            categoryLabel={note.data.categoryLabel}
            updated={note.data.updated}
            tags={note.data.tags}
          />
        ))}
      </div>
    </section>

    <aside class="detail-side">
      <section class="surface-muted section-tight info-card">
        <span class="info-label">概览</span>
        <div class="info-metrics">
          <div>
            <strong>{notes.length}</strong>
            <span>公开笔记</span>
          </div>
          <div>
            <strong>{tagGroups.length}</strong>
            <span>关联标签</span>
          </div>
          <div>
            <strong>{latestUpdated}</strong>
            <span>最近更新</span>
          </div>
        </div>
      </section>

      {tagGroups.length > 0 && (
        <section class="surface-muted section-tight info-card">
          <div class="info-head">
            <span class="info-label">高频标签</span>
            <a href={sitePath("tags/")}>全部标签</a>
          </div>
          <div class="chip-row">
            {tagGroups.map((tag) => (
              <a class="chip" href={sitePath(`tags/${tag.slug}/`)}>
                #{tag.label}
              </a>
            ))}
          </div>
        </section>
      )}
    </aside>
  </div>
</BaseLayout>

<style>
  .page-head {
    display: grid;
    gap: 14px;
    margin-top: 18px;
  }

  .page-head h1 {
    margin: 0;
    font-family: var(--font-serif);
    font-size: 2.7rem;
    font-weight: 600;
    line-height: 1.05;
  }

  .page-head p {
    margin: 0;
    max-width: 720px;
    color: var(--text-soft);
    line-height: 1.75;
  }

  .detail-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 300px;
    gap: 24px;
    align-items: start;
  }

  .note-stack {
    display: grid;
    margin-top: 18px;
  }

  .detail-side {
    display: grid;
    gap: 18px;
  }

  .info-card {
    display: grid;
    gap: 16px;
  }

  .info-head {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    align-items: center;
  }

  .info-head a {
    color: var(--accent);
    font-size: 0.86rem;
  }

  .info-label,
  .section-summary {
    color: var(--text-muted);
    font-size: 0.84rem;
    letter-spacing: 0.04em;
  }

  .info-metrics {
    display: grid;
    gap: 12px;
  }

  .info-metrics div {
    display: grid;
    gap: 4px;
  }

  .info-metrics strong {
    font-family: var(--font-serif);
    font-size: 1.1rem;
    font-weight: 600;
    line-height: 1.35;
  }

  .info-metrics span {
    color: var(--text-muted);
    font-size: 0.84rem;
  }

  @media (max-width: 1080px) {
    .detail-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 720px) {
    .page-head h1 {
      font-size: 2.2rem;
    }
  }
</style>
