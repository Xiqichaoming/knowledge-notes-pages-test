---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import SectionIntro from "../../components/SectionIntro.astro";
import { groupNotesByCategory, groupNotesByTag, sortNotes } from "../../lib/notes";
import { sitePath } from "../../lib/site-paths";
import { cleanDisplayText } from "../../lib/display-text";

const notes = sortNotes((await getCollection("notes")).filter((entry) => !entry.data.draft));
const categories = groupNotesByCategory(notes);
const tags = [...groupNotesByTag(notes)].sort(
  (left, right) => right.count - left.count || left.label.localeCompare(right.label)
);
---

<BaseLayout title="标签">
  <SectionIntro
    eyebrow="标签"
    title="按标签聚合"
    copy="标签用于横向串联概念、工具和问题，适合在不同专题之间快速跳转"
  />

  <section class="overview-grid">
    <article class="surface-muted section-tight stat-card">
      <span class="stat-label">标签数量</span>
      <strong class="stat-value">{tags.length}</strong>
    </article>
    <article class="surface-muted section-tight stat-card">
      <span class="stat-label">覆盖分类</span>
      <strong class="stat-value">{categories.length}</strong>
    </article>
    <article class="surface-muted section-tight stat-card">
      <span class="stat-label">公开笔记</span>
      <strong class="stat-value">{notes.length}</strong>
    </article>
  </section>

  <section class="surface section">
    <div class="section-head">
      <h2>标签目录</h2>
      <span class="section-summary">{tags.length} 个标签</span>
    </div>

    <div class="tag-grid">
      {tags.map((tag) => {
        const latestNote = tag.notes[0];
        const categoryCount = new Set(tag.notes.map((note) => note.data.category)).size;

        return (
          <a href={sitePath(`tags/${tag.slug}/`)} class="tag-card">
            <div class="tag-card-meta">
              <span>{tag.count} 篇笔记</span>
              <span>{categoryCount} 个分类</span>
            </div>
            <strong>#{tag.label}</strong>
            <p>{cleanDisplayText(latestNote?.data.summary ?? "这个标签用于串联相关内容")} </p>
            {latestNote && <span class="tag-card-latest">最近出现于《{latestNote.data.title}》</span>}
          </a>
        );
      })}
    </div>
  </section>
</BaseLayout>

<style>
  .overview-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
  }

  .stat-card {
    display: grid;
    gap: 10px;
    min-height: 104px;
    align-content: space-between;
  }

  .stat-label,
  .section-summary {
    color: var(--text-muted);
    font-size: 0.84rem;
    letter-spacing: 0.04em;
  }

  .stat-value {
    font-family: var(--font-serif);
    font-size: 2rem;
    font-weight: 600;
    line-height: 1.1;
  }

  .tag-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 360px), 1fr));
    gap: 18px;
    margin-top: 18px;
  }

  .tag-card {
    display: grid;
    gap: 12px;
    padding: 20px;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: rgba(255, 249, 242, 0.78);
  }

  .tag-card:hover {
    border-color: var(--accent-line);
    box-shadow: var(--shadow-soft);
  }

  .tag-card-meta {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 10px;
    color: var(--text-muted);
    font-size: 0.84rem;
  }

  .tag-card strong {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    font-weight: 600;
  }

  .tag-card p {
    margin: 0;
    color: var(--text-soft);
    line-height: 1.7;
    text-wrap: pretty;
  }

  .tag-card-latest {
    color: var(--text-muted);
    font-size: 0.86rem;
  }

  @media (max-width: 960px) {
    .overview-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
