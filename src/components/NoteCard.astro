---
import { sitePath } from "../lib/site-paths";
import { cleanDisplayText } from "../lib/display-text";

interface Props {
  href: string;
  title: string;
  summary: string;
  categoryLabel: string;
  updated: string;
  tags: string[];
}

const { href, title, summary, categoryLabel, updated, tags } = Astro.props;
const visibleTags = tags.slice(0, 3);
const displaySummary = cleanDisplayText(summary);
---

<article class="note-card">
  <div class="note-card-meta">
    <span class="note-card-category">{categoryLabel}</span>
    <time datetime={updated}>{updated}</time>
  </div>
  <h2 class="note-card-title">
    <a href={href}>{title}</a>
  </h2>
  <p class="note-card-summary">{displaySummary}</p>
  {visibleTags.length > 0 && (
    <div class="note-card-tags">
      {visibleTags.map((tag) => (
        <a href={sitePath(`tags/${tag}/`)}>#{tag}</a>
      ))}
    </div>
  )}
</article>

<style>
  .note-card {
    display: grid;
    gap: 14px;
    padding: 20px;
    background: rgba(255, 253, 250, 0.9);
    border: 1px solid var(--border);
    border-radius: 8px;
    transition: transform 180ms ease, border-color 180ms ease, box-shadow 180ms ease;
  }

  .note-card:hover {
    transform: translateY(-1px);
    border-color: var(--accent-line);
    box-shadow: var(--shadow-soft);
  }

  .note-card-meta {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 12px;
    color: var(--text-muted);
    font-size: 0.86rem;
  }

  .note-card-category {
    color: var(--accent);
  }

  .note-card-title {
    margin: 0;
    font-family: var(--font-serif);
    font-size: 1.2rem;
    font-weight: 600;
    line-height: 1.25;
  }

  .note-card-title a:hover {
    color: #0f766e;
  }

  .note-card-summary {
    margin: 0;
    color: var(--text-soft);
    line-height: 1.65;
  }

  .note-card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .note-card-tags a {
    padding: 6px 10px;
    border-radius: 999px;
    background: var(--accent-soft);
    color: var(--accent);
    font-size: 0.84rem;
  }
</style>
